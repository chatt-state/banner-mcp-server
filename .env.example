# Ethos Integration (primary auth method)
ETHOS_API_KEY=your-ethos-api-key
ETHOS_BASE_URL=https://integrate.elluciancloud.com

# Banner Native REST (optional, for direct Banner API access)
BANNER_BASE_URL=https://banner.yourschool.edu
BANNER_USERNAME=
BANNER_PASSWORD=

# MCP Transport
BANNER_MCP_TRANSPORT=stdio
BANNER_MCP_HTTP_PORT=3001
BANNER_MCP_HTTP_HOST=0.0.0.0

# Domains to pre-load at startup (comma-separated)
BANNER_PRELOAD_DOMAINS=student

# Logging
BANNER_LOG_LEVEL=info
